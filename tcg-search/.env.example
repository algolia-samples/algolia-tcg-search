# Algolia Configuration
# https://www.algolia.com/doc/guides/security/api-keys/#access-control-list-acl
VITE_ALGOLIA_APP_ID=your_app_id
VITE_ALGOLIA_API_KEY=your_search_api_key
VITE_ALGOLIA_INDEX_NAME=etail-west-tcg_cards

# Optional: Virtual replica index names for price sorting
# If not set, will default to ${VITE_ALGOLIA_INDEX_NAME}_price_asc and _price_desc
VITE_ALGOLIA_INDEX_NAME_PRICE_ASC=etail-west-tcg_cards_price_asc
VITE_ALGOLIA_INDEX_NAME_PRICE_DESC=etail-west-tcg_cards_price_desc

# Supabase Configuration (client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# User token for analytics tracking
VITE_USER_TOKEN=your_user_token
