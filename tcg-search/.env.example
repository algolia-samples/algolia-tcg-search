# Algolia Configuration
# https://www.algolia.com/doc/guides/security/api-keys/#access-control-list-acl
VITE_ALGOLIA_APP_ID=your_app_id
VITE_ALGOLIA_API_KEY=your_search_api_key
VITE_ALGOLIA_EVENTS_INDEX=tcg_events

# AI Chat Agent — fallback only; agent_id is read from the tcg_events record at runtime
VITE_ALGOLIA_CHAT_AGENT_ID=

# Supabase Configuration (client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# User token for analytics tracking
VITE_USER_TOKEN=your_user_token

# Server-side only (Vercel API routes)
SUPABASE_SECRET_KEY=your_supabase_service_role_key
ALGOLIA_WRITE_API_KEY=your_algolia_write_api_key
