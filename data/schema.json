{
  "schema": {
    "description": "Pokemon TCG Card Schema for Algolia Index",
    "fields": [
      {
        "name": "pokemon_name",
        "type": "string",
        "description": "Name of the Pokemon card or trainer card",
        "source_column": "Pokemon Name",
        "searchable": true,
        "filterable": false
      },
      {
        "name": "number",
        "type": "string",
        "description": "Card number within the set",
        "source_column": "Number ",
        "searchable": false,
        "filterable": true
      },
      {
        "name": "card_type",
        "type": "string",
        "description": "Type of card (Full Art, Holo, Alternative Full Art, Gold, Secret Art, Reverse Holo)",
        "source_column": "Card Type ",
        "searchable": true,
        "filterable": true,
        "facetable": true
      },
      {
        "name": "machine_quantity",
        "type": "integer",
        "description": "Number of cards available in the vending machine",
        "source_column": "# in Machine",
        "searchable": false,
        "filterable": true
      },
      {
        "name": "estimated_value",
        "type": "float",
        "description": "Estimated monetary value of the card in USD (nullable)",
        "source_column": "Estimated Value ",
        "searchable": false,
        "filterable": true,
        "nullable": true
      },
      {
        "name": "is_chase_card",
        "type": "boolean",
        "description": "Whether this is a chase card (highly desirable)",
        "source_column": "Is Chase Card? ",
        "searchable": false,
        "filterable": true,
        "facetable": true
      },
      {
        "name": "is_top_10_chase_card",
        "type": "boolean",
        "description": "Whether this is in the top 10 most desirable chase cards",
        "source_column": "Is top 10 chase card? ",
        "searchable": false,
        "filterable": true,
        "facetable": true
      },
      {
        "name": "is_classic_pokemon",
        "type": "boolean",
        "description": "Whether this features a classic/Generation 1 Pokemon",
        "source_column": "Is classic Pokemon? ",
        "searchable": false,
        "filterable": true,
        "facetable": true
      },
      {
        "name": "is_full_art",
        "type": "boolean",
        "description": "Whether this is a full art card",
        "source_column": "Is Full Art?  ",
        "searchable": false,
        "filterable": true,
        "facetable": true
      },
      {
        "name": "set_name",
        "type": "string",
        "description": "The card set name (derived from filename)",
        "source_column": "DERIVED",
        "searchable": true,
        "filterable": true,
        "facetable": true
      },
      {
        "name": "set_id",
        "type": "string",
        "description": "TCGdex set identifier (enriched from API)",
        "source_column": "ENRICHED",
        "searchable": false,
        "filterable": true
      },
      {
        "name": "image_small",
        "type": "string",
        "description": "Small image URL (245x337 webp, enriched from TCGdex)",
        "source_column": "ENRICHED",
        "searchable": false,
        "filterable": false
      },
      {
        "name": "image_large",
        "type": "string",
        "description": "Large image URL (600x825 webp, enriched from TCGdex)",
        "source_column": "ENRICHED",
        "searchable": false,
        "filterable": false
      }
    ],
    "algolia_configuration": {
      "searchableAttributes": [
        "pokemon_name",
        "card_type",
        "set_name"
      ],
      "attributesForFaceting": [
        "filterOnly(card_type)",
        "filterOnly(is_chase_card)",
        "filterOnly(is_top_10_chase_card)",
        "filterOnly(is_classic_pokemon)",
        "filterOnly(is_full_art)",
        "searchable(set_name)"
      ],
      "numericAttributesForFiltering": [
        "estimated_value",
        "machine_quantity"
      ],
      "customRanking": [
        "desc(is_top_10_chase_card)",
        "desc(is_chase_card)",
        "desc(estimated_value)"
      ]
    }
  }
}
